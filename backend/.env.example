NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Auth (JWT)
# -----------------------------------------------------------------------------
# Required. Use a long random secret in production (e.g. openssl rand -hex 32).
# Must match the frontend JWT_SECRET if you use Next.js middleware session cookies.
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Optional: access token lifetime (jsonwebtoken `expiresIn`, e.g. 15m, 7d)
# JWT_EXPIRES_IN=7d

# Optional: bcrypt cost factor (10–14; default 12 if unset or invalid)
# BCRYPT_COST=12

# -----------------------------------------------------------------------------
# OAuth (optional — leave unset to disable a provider)
# -----------------------------------------------------------------------------
# Public API origin (no trailing slash). Must match redirect URIs in provider consoles.
# Example: http://localhost:4000  or  https://api.yourdomain.com
# API_PUBLIC_URL=http://localhost:4000

# After OAuth, browser is redirected here with tokens in the URL **fragment** (not sent to servers):
#   #access_token=<jwt>&token_type=Bearer
# On failure: #error=oauth_failed&error_code=...&message=...
# FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/auth/oauth/callback

# Google — redirect URI: {API_PUBLIC_URL}/api/v1/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub — redirect URI: {API_PUBLIC_URL}/api/v1/auth/oauth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Apple — Sign in with Apple: redirect URI must be POST {API_PUBLIC_URL}/api/v1/auth/oauth/apple/callback (form_post)
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Or: APPLE_OAUTH_PRIVATE_KEY_BASE64=<base64 PEM>

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database

# -----------------------------------------------------------------------------
# Redis (Upstash)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# AI / voice providers (set as needed for assistants)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
