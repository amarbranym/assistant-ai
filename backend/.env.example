# Core
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Supabase — verify Auth access tokens (HS256 with project JWT secret)
SUPABASE_JWT_SECRET=

# Database
DATABASE_URL=

# Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Assistant chat — OpenAI (read by @ai-sdk/openai; required for streaming chat)
OPENAI_API_KEY=
